# API Keys Configuration for Hammerspoon
# Required by hammerspoon/.hammerspoon/languagetool.lua
#
# Usage:
#   1. Copy this file to ~/.env (in your home directory)
#   2. Add your actual API keys
#   3. Restart Hammerspoon

# Zhipu GLM API
# Get your API key from: https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key_here

# MiniMax API
# Get your API key from: https://platform.minimax.chat/
MINIMAX_API_KEY=your_minimax_api_key_here
